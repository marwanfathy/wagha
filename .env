# Copy this file to .env.local and fill in real values for your environment.
# All URLs the app talks to are driven from here — nothing should be hardcoded in source.
# Edit these directly to change any URL — the script replaces the entire value, not just the IP.

# Main backend API origin (no trailing slash, no /api/v1 — lib/api.ts appends that)
NEXT_PUBLIC_API_URL=http://192.168.1.18:4000

# Media server origin (serves uploaded images/files, separate service from the API above)
NEXT_PUBLIC_MEDIA_URL=http://192.168.1.18:5002
